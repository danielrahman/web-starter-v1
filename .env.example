# Core mode switch
CMS_ENABLED=false
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# File fallback policy when CMS_ENABLED=true:
# - always (default in development): fallback for empty state and runtime errors
# - bootstrap (default in production): fallback only for empty initial state
# - never: never fallback to /content from Payload mode
CMS_FILE_FALLBACK_MODE=

# Optional contact email sending (Mode A and Mode B)
RESEND_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=

# Required when CMS_ENABLED=true
PAYLOAD_SECRET=
# Turso remote: libsql://<db-name>-<org>.turso.io
# Local dev fallback: file:./payload.db
DATABASE_URL=
TURSO_AUTH_TOKEN=
# Example: https://<account-id>.r2.cloudflarestorage.com
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public CDN/domain for uploaded media URLs
S3_PUBLIC_BASE_URL=

# Optional defaults for npm run payload:create-admin
PAYLOAD_ADMIN_EMAIL=rahman.daniel3@gmail.com
PAYLOAD_ADMIN_PASSWORD=
